# Copy to .env and fill in real values. Never commit .env to git.

# Required — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=REPLACE_WITH_YOUR_GENERATED_KEY

# Optional — set to a registered username to grant admin panel access.
# Register the account normally first, then set this and restart.
ADMIN_USERNAME=admin
